{
	"openapi": "3.0.0",
	"components": {
		"examples": {},
		"headers": {},
		"parameters": {},
		"requestBodies": {},
		"responses": {},
		"schemas": {
			"User": {
				"properties": {
					"uuid": {
						"type": "string",
						"example": "123e4567-e89b-12d3-a456-426614174000"
					},
					"username": {
						"type": "string",
						"example": "admin"
					},
					"email": {
						"type": "string",
						"example": "admin@example.com"
					},
					"displayName": {
						"type": "string",
						"nullable": true,
						"example": "John Doe"
					},
					"role": {
						"type": "string",
						"enum": [
							"USER",
							"MOD",
							"ADMIN"
						],
						"example": "USER"
					},
					"createdAt": {
						"type": "string",
						"format": "date-time",
						"example": "2024-01-01T00:00:00.000Z"
					}
				},
				"required": [
					"uuid",
					"username",
					"email",
					"role",
					"createdAt"
				],
				"type": "object",
				"additionalProperties": false
			},
			"Note": {
				"properties": {
					"uuid": {
						"type": "string",
						"example": "123e4567-e89b-12d3-a456-426614174000"
					},
					"title": {
						"type": "string",
						"example": "My first note"
					},
					"content": {
						"type": "string",
						"example": "This is the content of my first note."
					},
					"authorId": {
						"type": "number",
						"format": "double",
						"example": 1
					},
					"createdAt": {
						"type": "string",
						"format": "date-time",
						"example": "2024-01-01T00:00:00.000Z"
					}
				},
				"required": [
					"uuid",
					"title",
					"content",
					"authorId",
					"createdAt"
				],
				"type": "object",
				"additionalProperties": false
			},
			"NoteOnUser": {
				"properties": {
					"noteId": {
						"type": "number",
						"format": "double",
						"example": 1
					},
					"userId": {
						"type": "number",
						"format": "double",
						"example": 1
					},
					"assignedById": {
						"type": "number",
						"format": "double",
						"example": 1
					},
					"assignedAt": {
						"type": "string",
						"format": "date-time",
						"example": "2024-01-01T00:00:00.000Z"
					},
					"role": {
						"type": "string",
						"enum": [
							"USER",
							"MOD",
							"ADMIN"
						],
						"example": "USER"
					},
					"note": {
						"$ref": "#/components/schemas/Note"
					}
				},
				"required": [
					"noteId",
					"userId",
					"assignedById",
					"assignedAt",
					"role"
				],
				"type": "object",
				"additionalProperties": false
			},
			"NoteCreateRequest": {
				"properties": {
					"title": {
						"type": "string",
						"example": "My first note",
						"minLength": 3
					},
					"content": {
						"type": "string",
						"example": "This is the content of my first note.",
						"minLength": 3
					}
				},
				"required": [
					"title",
					"content"
				],
				"type": "object",
				"additionalProperties": false
			},
			"NoteOnUserCreateRequest": {
				"properties": {
					"noteId": {
						"type": "integer",
						"format": "int32",
						"example": 1
					},
					"userId": {
						"type": "integer",
						"format": "int32",
						"example": 1
					}
				},
				"required": [
					"noteId",
					"userId"
				],
				"type": "object",
				"additionalProperties": false
			},
			"RegisterRequest": {
				"properties": {
					"username": {
						"type": "string",
						"example": "newuser",
						"minLength": 3
					},
					"password": {
						"type": "string",
						"example": "secret123",
						"minLength": 6
					},
					"email": {
						"type": "string",
						"example": "user@example.com",
						"format": "email",
						"pattern": "^(.+)@(.+)\\.(.+)$"
					},
					"displayName": {
						"type": "string",
						"nullable": true,
						"example": "John Doe"
					}
				},
				"required": [
					"username",
					"password",
					"email"
				],
				"type": "object",
				"additionalProperties": false
			},
			"AuthResponse": {
				"properties": {
					"accessToken": {
						"type": "string",
						"example": "eyJhbGciOiJI..."
					},
					"accessTokenExpiresOn": {
						"type": "number",
						"format": "double",
						"example": 1772719299
					},
					"refreshTokenExpiresOn": {
						"type": "number",
						"format": "double",
						"example": 1773324099
					}
				},
				"required": [
					"accessToken",
					"accessTokenExpiresOn",
					"refreshTokenExpiresOn"
				],
				"type": "object",
				"additionalProperties": false
			},
			"LoginRequest": {
				"properties": {
					"username": {
						"type": "string",
						"example": "admin",
						"minLength": 1
					},
					"password": {
						"type": "string",
						"example": "admin",
						"minLength": 1
					}
				},
				"required": [
					"username",
					"password"
				],
				"type": "object",
				"additionalProperties": false
			}
		},
		"securitySchemes": {
			"jwt": {
				"type": "apiKey",
				"name": "Authorization",
				"in": "header"
			}
		}
	},
	"info": {
		"title": "insane-node-rest-api",
		"version": "1.0.0",
		"license": {
			"name": "MIT"
		},
		"contact": {
			"name": "lucasdee"
		}
	},
