{
	"openapi": "3.0.0",
	"components": {
		"examples": {},
		"headers": {},
		"parameters": {},
		"requestBodies": {},
		"responses": {},
		"schemas": {
			"User": {
				"properties": {
					"uuid": {
						"type": "string",
						"example": "123e4567-e89b-12d3-a456-426614174000"
					},
					"username": {
						"type": "string",
						"example": "admin"
					},
					"email": {
						"type": "string",
						"example": "admin@example.com"
					},
					"displayName": {
						"type": "string",
						"nullable": true,
						"example": "John Doe"
					},
					"role": {
						"type": "string",
						"enum": [
							"USER",
							"MOD",
							"ADMIN"
						],
						"example": "USER"
					},
					"createdAt": {
						"type": "string",
						"format": "date-time",
						"example": "2024-01-01T00:00:00.000Z"
					}
				},
				"required": [
					"uuid",
					"username",
					"email",
					"role",
					"createdAt"
				],
				"type": "object",
				"additionalProperties": false
			},
			"RegisterRequest": {
				"properties": {
					"username": {
						"type": "string",
						"example": "newuser",
						"minLength": 3
					},
					"password": {
						"type": "string",
						"example": "secret123",
						"minLength": 6
					},
					"email": {
						"type": "string",
						"example": "user@example.com",
						"format": "email",
						"pattern": "^(.+)@(.+)\\.(.+)$"
					},
					"displayName": {
						"type": "string",
						"nullable": true,
						"example": "John Doe"
					}
				},
				"required": [
					"username",
					"password",
					"email"
				],
				"type": "object",
				"additionalProperties": false
			},
			"AuthResponse": {
				"properties": {
					"token": {
						"type": "string",
						"example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
					}
				},
				"required": [
					"token"
				],
				"type": "object",
				"additionalProperties": false
			},
			"LoginRequest": {
				"properties": {
					"username": {
						"type": "string",
						"example": "admin",
						"minLength": 1
					},
					"password": {
						"type": "string",
						"example": "admin",
						"minLength": 1
					}
				},
				"required": [
					"username",
					"password"
				],
				"type": "object",
				"additionalProperties": false
			}
		},
		"securitySchemes": {
			"jwt": {
				"type": "apiKey",
				"name": "Authorization",
				"in": "header"
			}
		}
	},
	"info": {
		"title": "insane-node-rest-api",
		"version": "1.0.0",
		"license": {
			"name": "MIT"
		},
		"contact": {
			"name": "lucasdee"
		}
	},
	"paths": {
		"/users/me": {
			"get": {
				"operationId": "GetProfile",
				"responses": {
					"200": {
						"description": "Ok",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/User"
								}
							}
						}
					}
				},
				"tags": [
					"Users"
				],
				"security": [
					{
						"jwt": []
					}
				],
				"parameters": []
			}
		},
		"/auth/register": {
			"post": {
				"operationId": "Register",
				"responses": {
					"200": {
						"description": "Ok",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/User"
								}
							}
						}
					}
				},
				"tags": [
					"Auth"
				],
				"security": [],
				"parameters": [],
				"requestBody": {
					"required": true,
					"content": {
						"application/json": {
							"schema": {
								"$ref": "#/components/schemas/RegisterRequest"
							}
						}
					}
				}
			}
		},
		"/auth/login": {
			"post": {
				"operationId": "Login",
				"responses": {
					"200": {
						"description": "Ok",
						"content": {
							"application/json": {
								"schema": {
									"$ref": "#/components/schemas/AuthResponse"
								}
							}
						}
					}
				},
				"tags": [
					"Auth"
				],
				"security": [],
				"parameters": [],
				"requestBody": {
					"required": true,
					"content": {
						"application/json": {
							"schema": {
								"$ref": "#/components/schemas/LoginRequest"
							}
						}
					}
				}
			}
		}
	},
	"servers": [
		{
			"url": "/"
		}
	]
}