					}
				],
				"parameters": [],
				"requestBody": {
					"required": true,
					"content": {
						"application/json": {
							"schema": {
								"$ref": "#/components/schemas/NoteOnUserCreateRequest"
							}
						}
					}
				}
			}
		},
